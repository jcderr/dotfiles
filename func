# logging convenience
autoload colors

if [[ "$terminfo[colors]" -gt 8 ]]; then
    colors
fi

for COLOR in RED GREEN YELLOW BLUE MAGENTA CYAN BLACK WHITE; do
    eval ${COLOR}='$fg_no_bold[${(L)COLOR}]'
    eval BOLD_${COLOR}='$fg_bold[${(L)COLOR}]'
done

function error() {
    echo "${RED}[ERROR] ${1}${RESET}"
}

function info() {
    echo "${CYAN}[INFO] ${1}${RESET}"
}

eval RESET='$reset_color'

# call URL, print status code
statuscode () {
    info "http.status_code = $(curl -o /dev/null --insecure --silent --head --write-out '%{http_code}' $1)"
}

# flush dns cache
flush_dns() {
    sudo dscacheutil -flushcache && sudo killall -HUP mDNSResponder && info "DNS Flushed"
}

# load an environment file from ~/.zsh.envs
environ() {
    _environ=$1
    [[ -n "$1" ]] || error "Please specify an environment."

    [[ -e "${HOME}/.zsh.envs/$1" ]] || error "Environment not found: $1"

    info "Activating $1..."
    . ~/.zsh.envs/$1
    export ENVIRON_NAME=$1
}


s() {
    if [ -n "$1" ]; then
        cd ~/src/$1
    else
        ls ~/src/
    fi
}

e() {
    if [ -n "$1" ]; then
        cd ~/src/_env/$1
    else
        ls ~/src/_env
    fi
}

imagestatus() {
    image_id=${1}
    info "Checking $image_id"
    while true; do
        RES=$(aws --region us-east-1 ec2 describe-images --image-id ${image_id} --query 'Images[*].State' --output text)
        if [[ "$RES" -ne "pending" ]]; then
            break
        fi
    done
}

# Stop disk-dependent services before unplugging /Volumes/Junk
undock() {
  local PLIST=~/Library/LaunchAgents/me.derr.adult-encode-watcher.plist
  local STATE=/tmp/adult_encode_interrupted.txt

  local partial
  partial=$(lsof -c ffmpeg 2>/dev/null | awk '$4 ~ /[0-9]+w/ { print $NF }' | grep "^/Volumes/Junk/Adult/Processed/" | head -1)
  if [[ -n "$partial" ]]; then
    echo "$partial" > "$STATE"
    info "saved interrupted encode: $(basename $partial)"
  fi

  pkill -x ffmpeg 2>/dev/null && info "ffmpeg killed" || info "ffmpeg not running"
  launchctl unload "$PLIST" 2>/dev/null && info "encode watcher unloaded" || info "encode watcher not loaded"
  colima stop && info "colima stopped"
}

# Restart disk-dependent services after plugging /Volumes/Junk back in
dock() {
  local PLIST=~/Library/LaunchAgents/me.derr.adult-encode-watcher.plist
  local STATE=/tmp/adult_encode_interrupted.txt

  colima start

  if [[ -f "$STATE" ]]; then
    local partial=$(cat "$STATE")
    if [[ -f "$partial" ]]; then
      rm "$partial"
      info "removed partial encode: $(basename $partial)"
    fi
    rm "$STATE"
  fi

  launchctl load "$PLIST" && info "encode watcher loaded"
  python3 /usr/local/bin/adult_encode_watcher.py &>> /tmp/adult_encode_watcher.log &
  info "encode scan started (pid $!)"
}

